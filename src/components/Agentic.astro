---
const offerings = [
  {
    title: "Agentic applications",
    description:
      "Software that uses large language models as the reasoning core — multi-step agents that plan, call tools, and act on internal systems and external APIs.",
    icon: "nodes",
  },
  {
    title: "Chat BI & data agents",
    description:
      "Natural-language interfaces over your data warehouse. Questions in plain English, answers generated from SQL, dbt, or your existing semantic layer.",
    icon: "chat-data",
  },
  {
    title: "LLM integration & evals",
    description:
      "Production-grade integration of Claude, GPT, and open-weight models — with evaluation, guardrails, and observability suited to real workloads.",
    icon: "spark",
  },
];
---
<section class="bg-slate-900 text-white">
  <div class="mx-auto max-w-5xl px-6 py-20 sm:py-24">
    <div class="max-w-2xl">
      <p class="text-sm font-medium uppercase tracking-[0.18em] text-accent-400">
        Agentic AI
      </p>
      <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
        We build agentic software.
      </h2>
      <p class="mt-5 text-base leading-relaxed text-slate-300">
        Beyond traditional software and data work, Datagrove designs and ships
        AI systems that <em class="not-italic text-white">do things</em> —
        agents reasoning over your tools, your data, and your business logic.
        Practical applications, integrated where they earn their keep.
      </p>
    </div>

    <ul class="mt-14 grid gap-x-10 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
      {offerings.map((item) => (
        <li>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-800 text-accent-400 ring-1 ring-slate-700">
            {item.icon === "nodes" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="5" r="2" />
                <circle cx="5" cy="19" r="2" />
                <circle cx="19" cy="19" r="2" />
                <path d="M12 7v4" />
                <path d="m11 12-5 5" />
                <path d="m13 12 5 5" />
                <circle cx="12" cy="12" r="1.5" />
              </svg>
            )}
            {item.icon === "chat-data" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12c0 4-4 7-9 7a10 10 0 0 1-3.5-.6L4 20l1.2-3.5A6.7 6.7 0 0 1 3 12c0-4 4-7 9-7s9 3 9 7Z" />
                <path d="M8.5 13v-2" />
                <path d="M12 13V9" />
                <path d="M15.5 13v-3" />
              </svg>
            )}
            {item.icon === "spark" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3v4" />
                <path d="M12 17v4" />
                <path d="M3 12h4" />
                <path d="M17 12h4" />
                <path d="m5.6 5.6 2.8 2.8" />
                <path d="m15.6 15.6 2.8 2.8" />
                <path d="m5.6 18.4 2.8-2.8" />
                <path d="m15.6 8.4 2.8-2.8" />
              </svg>
            )}
          </div>
          <h3 class="mt-5 text-base font-semibold text-white">
            {item.title}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">
            {item.description}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
