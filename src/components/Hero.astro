---
---
<section class="relative overflow-hidden">
  <div class="mx-auto max-w-4xl px-6 pt-24 pb-20 sm:pt-32 sm:pb-28">
    <p class="text-sm font-medium uppercase tracking-[0.18em] text-accent-600">
      Software · Data · AI
    </p>

    <h1 class="mt-6 text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl">
      Senior engineering,
      <span class="block">
        delivered <span class="relative inline-block">
          <span class="relative z-10">as a partner.</span>
          <span class="absolute inset-x-0 bottom-1 -z-0 h-3 bg-accent-200/70"></span>
        </span>
      </span>
    </h1>

    <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600">
      Datagrove designs, builds, and maintains software systems, data pipelines,
      cloud platforms, and agentic AI applications. We work as a subcontracting
      partner to consulting firms and deliver directly to companies that need a
      focused engineering team.
    </p>

    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a
        href="#contact"
        class="inline-flex items-center gap-2 rounded-full bg-slate-900 px-6 py-3 text-sm font-medium text-white shadow-sm hover:bg-slate-800 transition-colors"
      >
        Get in touch
        <svg
          viewBox="0 0 20 20"
          aria-hidden="true"
          class="h-4 w-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 10h12" />
          <path d="M12 4l6 6-6 6" />
        </svg>
      </a>
      <a
        href="#services"
        class="text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors"
      >
        See what we do →
      </a>
    </div>
  </div>
</section>
