---
interface Props {
  showBlog?: boolean;
}

const { showBlog = false } = Astro.props;
---
<header class="border-b border-slate-100">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-5">
    <a href="/" class="flex items-center gap-2 text-slate-900">
      <svg
        viewBox="0 0 24 24"
        aria-hidden="true"
        class="h-6 w-6 text-grove-600"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 21V11" />
        <path d="M12 11c0-3.5 2.5-6 6-6 0 3.5-2.5 6-6 6Z" />
        <path d="M12 11c0-3-2-5-5-5 0 3 2 5 5 5Z" />
      </svg>
      <span class="text-base font-semibold tracking-tight">Datagrove</span>
    </a>

    <nav class="flex items-center gap-6 text-sm text-slate-600">
      <a href="/#services" class="hover:text-slate-900 transition-colors">Services</a>
      {showBlog && (
        <a href="/blog" class="hover:text-slate-900 transition-colors">Writing</a>
      )}
      <a
        href="/#contact"
        class="rounded-full bg-slate-900 px-4 py-1.5 text-white hover:bg-slate-800 transition-colors"
      >
        Contact
      </a>
    </nav>
  </div>
</header>
