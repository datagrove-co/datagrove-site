---
const consulting = [
  {
    title: "Data strategy & roadmap",
    description:
      "Define the use cases, the platform shape, and the order to deliver them. Honest trade-offs over framework wars.",
    icon: "compass",
  },
  {
    title: "Architecture & technology selection",
    description:
      "Pick the right combination of cloud, storage, and processing for your workload and your team, not the vendor pitch.",
    icon: "layers",
  },
  {
    title: "Audits & due diligence",
    description:
      "Independent review of an existing data platform: scale headroom, cost profile, reliability, and the moves that matter next.",
    icon: "search",
  },
];

const agentic = [
  {
    title: "Agentic applications",
    description:
      "Software that uses large language models as the reasoning core: multi-step agents that plan, call tools, and act on internal systems and external APIs.",
    icon: "nodes",
  },
  {
    title: "Chat BI & data agents",
    description:
      "Natural-language interfaces over your data warehouse. Questions in plain English, answers generated from SQL, dbt, or your existing semantic layer.",
    icon: "chat-data",
  },
  {
    title: "LLM integration & evals",
    description:
      "Production-grade integration of Claude, GPT, and open-weight models, with evaluation, guardrails, and observability suited to real workloads.",
    icon: "spark",
  },
];

const engineering = [
  {
    title: "Software engineering",
    description:
      "Design and implementation of applications, services, and APIs, from greenfield builds to long-running platforms.",
    icon: "code",
  },
  {
    title: "Data engineering",
    description:
      "Ingestion, transformation, and modelling. Batch and streaming pipelines that move data reliably between systems.",
    icon: "stream",
  },
  {
    title: "Cloud solutions",
    description:
      "Architecture and delivery on AWS, GCP, and Azure. Infrastructure that fits the workload, not the brochure.",
    icon: "cloud",
  },
  {
    title: "Database services",
    description:
      "Schema design, performance tuning, and migrations on relational and analytical databases at production scale.",
    icon: "database",
  },
];
---
<section id="services" class="bg-white text-slate-800">
  <div class="mx-auto max-w-5xl px-6 py-20 sm:py-24">
    <div class="max-w-2xl">
      <p class="text-sm font-medium uppercase tracking-[0.18em] text-accent-700">
        What we do
      </p>
      <h2 class="mt-4 text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
        Three practices, one team.
      </h2>
      <p class="mt-5 text-base leading-relaxed text-slate-700">
        Datagrove operates across three connected disciplines: advising on what
        to build, building agentic AI applications, and shipping software and
        data systems end to end. The work moves between them as the project
        needs, without handoffs between separate firms.
      </p>
    </div>

    <!-- Visual break 1 -->
    <figure class="mt-16">
      <img
        src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=2000&q=85"
        alt="A team collaborating around a whiteboard covered in sticky notes."
        width="2000"
        height="800"
        loading="lazy"
        decoding="async"
        class="aspect-[5/2] w-full rounded-2xl object-cover ring-1 ring-slate-200"
      />
    </figure>

    <!-- Subsection 1: Technology Consulting -->
    <div class="mt-20 border-t border-slate-200 pt-16">
      <div class="grid gap-10 lg:grid-cols-12">
        <div class="lg:col-span-4">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent-700">
            01. Technology Consulting
          </p>
          <h3 class="mt-4 text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
            Build a data strategy that holds up at scale.
          </h3>
          <p class="mt-5 text-sm leading-relaxed text-slate-700">
            We have worked on data platforms across a range of industries and
            technology stacks. That experience shapes the advice we give:
            practical, opinionated where it counts, and grounded in what
            actually runs in production, not what looks good in a slide deck.
          </p>
        </div>

        <ul class="lg:col-span-8 grid gap-x-10 gap-y-10 sm:grid-cols-2">
          {consulting.map((item) => (
            <li>
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent-50 text-accent-700 ring-1 ring-accent-100">
                {item.icon === "compass" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="9" />
                    <path d="m15 9-4 1.5L9.5 15 13.5 13.5 15 9Z" />
                  </svg>
                )}
                {item.icon === "layers" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m12 3 9 5-9 5-9-5 9-5Z" />
                    <path d="m3 13 9 5 9-5" />
                    <path d="m3 18 9 5 9-5" />
                  </svg>
                )}
                {item.icon === "search" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="7" />
                    <path d="m21 21-4.3-4.3" />
                  </svg>
                )}
              </div>
              <h4 class="mt-4 text-base font-semibold text-slate-900">
                {item.title}
              </h4>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">
                {item.description}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Subsection 2: Agentic AI -->
    <div class="mt-20 border-t border-slate-200 pt-16">
      <div class="grid gap-10 lg:grid-cols-12">
        <div class="lg:col-span-4">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent-700">
            02. Agentic AI
          </p>
          <h3 class="mt-4 text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
            We build agentic software.
          </h3>
          <p class="mt-5 text-sm leading-relaxed text-slate-700">
            Beyond traditional software and data work, Datagrove designs and
            ships AI systems that <em class="not-italic text-slate-900">do things</em>:
            agents reasoning over your tools, your data, and your business
            logic. Practical applications, integrated where they earn their keep.
          </p>
        </div>

        <ul class="lg:col-span-8 grid gap-x-10 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
          {agentic.map((item) => (
            <li>
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent-50 text-accent-700 ring-1 ring-accent-100">
                {item.icon === "nodes" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="5" r="2" />
                    <circle cx="5" cy="19" r="2" />
                    <circle cx="19" cy="19" r="2" />
                    <path d="M12 7v4" />
                    <path d="m11 12-5 5" />
                    <path d="m13 12 5 5" />
                    <circle cx="12" cy="12" r="1.5" />
                  </svg>
                )}
                {item.icon === "chat-data" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 12c0 4-4 7-9 7a10 10 0 0 1-3.5-.6L4 20l1.2-3.5A6.7 6.7 0 0 1 3 12c0-4 4-7 9-7s9 3 9 7Z" />
                    <path d="M8.5 13v-2" />
                    <path d="M12 13V9" />
                    <path d="M15.5 13v-3" />
                  </svg>
                )}
                {item.icon === "spark" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 3v4" />
                    <path d="M12 17v4" />
                    <path d="M3 12h4" />
                    <path d="M17 12h4" />
                    <path d="m5.6 5.6 2.8 2.8" />
                    <path d="m15.6 15.6 2.8 2.8" />
                    <path d="m5.6 18.4 2.8-2.8" />
                    <path d="m15.6 8.4 2.8-2.8" />
                  </svg>
                )}
              </div>
              <h4 class="mt-4 text-base font-semibold text-slate-900">
                {item.title}
              </h4>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">
                {item.description}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Subsection 3: Software & Data Engineering -->
    <div class="mt-20 border-t border-slate-200 pt-16">
      <div class="grid gap-10 lg:grid-cols-12">
        <div class="lg:col-span-4">
          <p class="font-mono text-xs uppercase tracking-[0.18em] text-accent-700">
            03. Software &amp; Data Engineering
          </p>
          <h3 class="mt-4 text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
            Engineering teams that ship, end to end.
          </h3>
          <p class="mt-5 text-sm leading-relaxed text-slate-700">
            From architecture through hands-on development and operational
            handover, Datagrove builds and operates production software and data
            systems. We tend to stay involved through rollout and the early
            production weeks, the part where systems usually break.
          </p>
        </div>

        <ul class="lg:col-span-8 grid gap-x-10 gap-y-10 sm:grid-cols-2">
          {engineering.map((item) => (
            <li>
              <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent-50 text-accent-700 ring-1 ring-accent-100">
                {item.icon === "code" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m8 8-5 4 5 4" />
                    <path d="m16 8 5 4-5 4" />
                    <path d="m14 4-4 16" />
                  </svg>
                )}
                {item.icon === "stream" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 7h10" />
                    <path d="M4 12h16" />
                    <path d="M4 17h7" />
                    <circle cx="18" cy="7" r="1.4" />
                    <circle cx="15" cy="17" r="1.4" />
                  </svg>
                )}
                {item.icon === "cloud" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M7 18a4 4 0 0 1-.5-7.97A6 6 0 0 1 18 10.5a3.5 3.5 0 0 1-.5 7H7Z" />
                  </svg>
                )}
                {item.icon === "database" && (
                  <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                    <ellipse cx="12" cy="5" rx="8" ry="3" />
                    <path d="M4 5v6c0 1.66 3.58 3 8 3s8-1.34 8-3V5" />
                    <path d="M4 11v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6" />
                  </svg>
                )}
              </div>
              <h4 class="mt-4 text-base font-semibold text-slate-900">
                {item.title}
              </h4>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">
                {item.description}
              </p>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- End-of-section image: pair programming -->
    <figure class="mt-20">
      <img
        src="https://images.unsplash.com/photo-1632910121591-29e2484c0259?auto=format&fit=crop&w=2000&q=85"
        alt="Two software engineers working through code together at a workstation."
        width="2000"
        height="800"
        loading="lazy"
        decoding="async"
        class="aspect-[5/2] w-full rounded-2xl object-cover ring-1 ring-slate-200"
      />
    </figure>
  </div>
</section>
