---
const services = [
  {
    title: "Software engineering",
    description:
      "Design and implementation of applications, services, and APIs — from greenfield builds to long-running platforms.",
    icon: "code",
  },
  {
    title: "Data engineering",
    description:
      "Ingestion, transformation, and modelling. Batch and streaming pipelines that move data reliably between systems.",
    icon: "stream",
  },
  {
    title: "Cloud solutions",
    description:
      "Architecture and delivery on AWS, GCP, and Azure. Infrastructure that fits the workload, not the brochure.",
    icon: "cloud",
  },
  {
    title: "Database development",
    description:
      "Schema design, performance work, and migrations on relational and analytical databases.",
    icon: "database",
  },
  {
    title: "Systems integration",
    description:
      "Connecting the systems a business already depends on — internal services, third-party APIs, and legacy platforms.",
    icon: "plug",
  },
  {
    title: "Technology consulting",
    description:
      "Practical advice on architecture, tooling, and engineering practice, grounded in delivery experience.",
    icon: "compass",
  },
];
---
<section id="services" class="border-t border-slate-100 bg-slate-50/60">
  <div class="mx-auto max-w-5xl px-6 py-20 sm:py-24">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
        What we do
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Six things, done seriously. Each one stands on its own; together they cover
        most of what a modern engineering team is asked to deliver.
      </p>
    </div>

    <ul class="mt-14 grid gap-x-10 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((service) => (
        <li>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-grove-50 text-grove-700 ring-1 ring-grove-100">
            {service.icon === "code" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="m8 8-5 4 5 4" />
                <path d="m16 8 5 4-5 4" />
                <path d="m14 4-4 16" />
              </svg>
            )}
            {service.icon === "stream" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 7h10" />
                <path d="M4 12h16" />
                <path d="M4 17h7" />
                <circle cx="18" cy="7" r="1.4" />
                <circle cx="15" cy="17" r="1.4" />
              </svg>
            )}
            {service.icon === "cloud" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M7 18a4 4 0 0 1-.5-7.97A6 6 0 0 1 18 10.5a3.5 3.5 0 0 1-.5 7H7Z" />
              </svg>
            )}
            {service.icon === "database" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <ellipse cx="12" cy="5" rx="8" ry="3" />
                <path d="M4 5v6c0 1.66 3.58 3 8 3s8-1.34 8-3V5" />
                <path d="M4 11v6c0 1.66 3.58 3 8 3s8-1.34 8-3v-6" />
              </svg>
            )}
            {service.icon === "plug" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 2v4" />
                <path d="M15 2v4" />
                <path d="M7 6h10v4a5 5 0 0 1-5 5 5 5 0 0 1-5-5V6Z" />
                <path d="M12 15v7" />
              </svg>
            )}
            {service.icon === "compass" && (
              <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9" />
                <path d="m15 9-4 1.5L9.5 15 13.5 13.5 15 9Z" />
              </svg>
            )}
          </div>
          <h3 class="mt-5 text-base font-semibold text-slate-900">
            {service.title}
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">
            {service.description}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
