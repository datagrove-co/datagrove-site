---
const WEB3FORMS_ACCESS_KEY = "YOUR_WEB3FORMS_ACCESS_KEY";
---
<section id="contact" class="border-t border-slate-100">
  <div class="mx-auto max-w-3xl px-6 py-20 sm:py-24">
    <div class="max-w-xl">
      <h2 class="text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
        Let's talk
      </h2>
      <p class="mt-4 text-lg text-slate-600">
        Tell us about the work. We'll reply within a couple of business days.
      </p>
    </div>

    <form
      id="contact-form"
      class="mt-10 grid gap-5"
      novalidate
    >
      <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
      <input type="hidden" name="subject" value="New enquiry via datagrove.co" />
      <input type="hidden" name="from_name" value="datagrove.co" />
      <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

      <div class="grid gap-5 sm:grid-cols-2">
        <label class="block">
          <span class="text-sm font-medium text-slate-700">Name</span>
          <input
            type="text"
            name="name"
            required
            autocomplete="name"
            class="mt-2 block w-full rounded-lg border border-slate-200 bg-white px-3.5 py-2.5 text-slate-900 placeholder:text-slate-400 focus:border-grove-500 focus:outline-none focus:ring-2 focus:ring-grove-200"
          />
        </label>
        <label class="block">
          <span class="text-sm font-medium text-slate-700">Email</span>
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="mt-2 block w-full rounded-lg border border-slate-200 bg-white px-3.5 py-2.5 text-slate-900 placeholder:text-slate-400 focus:border-grove-500 focus:outline-none focus:ring-2 focus:ring-grove-200"
          />
        </label>
      </div>

      <label class="block">
        <span class="text-sm font-medium text-slate-700">Message</span>
        <textarea
          name="message"
          required
          rows="5"
          class="mt-2 block w-full rounded-lg border border-slate-200 bg-white px-3.5 py-2.5 text-slate-900 placeholder:text-slate-400 focus:border-grove-500 focus:outline-none focus:ring-2 focus:ring-grove-200"
        ></textarea>
      </label>

      <div class="flex items-center justify-between gap-4">
        <p id="contact-status" class="text-sm text-slate-500" role="status" aria-live="polite"></p>
        <button
          type="submit"
          class="inline-flex items-center gap-2 rounded-full bg-slate-900 px-6 py-3 text-sm font-medium text-white shadow-sm hover:bg-slate-800 transition-colors disabled:cursor-not-allowed disabled:opacity-60"
        >
          Send message
        </button>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("contact-status");

  if (form && status) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      const submitButton = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      if (submitButton) submitButton.disabled = true;
      status.textContent = "Sending…";
      status.className = "text-sm text-slate-500";

      const data = new FormData(form);

      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: data,
      });

      const result = await response.json().catch(() => ({}));

      if (response.ok && result.success) {
        form.reset();
        status.textContent = "Thanks — we'll reply soon.";
        status.className = "text-sm text-grove-700";
      } else {
        status.textContent =
          result.message ?? "Something went wrong. Please email us directly.";
        status.className = "text-sm text-red-600";
      }

      if (submitButton) submitButton.disabled = false;
    });
  }
</script>
